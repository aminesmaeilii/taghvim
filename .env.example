# Public Vite variables. Only variables prefixed with VITE_ are exposed to the browser bundle.
VITE_APP_NAME=Zambil Content Calendar
VITE_APP_ENV=development
VITE_FRONTEND_URL=https://taghvim.vercel.app
VITE_API_URL=http://localhost:3000
VITE_PUBLIC_WEB_PUSH_KEY=
VITE_VAPID_PUBLIC_KEY=
BACKEND_URL=https://taghvim.onrender.com
ALLOWED_ORIGINS=https://taghvim.vercel.app
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Required for persistent backend storage on Render.
# Keep these server-side in Render Environment Variables, not in frontend env files.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Future PostgreSQL runtime integration.
DATABASE_URL=
DATABASE_SSL=true
DATABASE_POOL_MAX=5
DATABASE_MIGRATION_URL=

# Required for production scheduled functions. Do not expose to frontend.
CRON_SECRET=

# Required for production direct blob uploads until server-authenticated uploads are implemented.
# If set, clients must call /api/blob-upload with Authorization: Bearer <BLOB_UPLOAD_SECRET>.
BLOB_UPLOAD_SECRET=

# Future worker/runtime settings.
WORKER_CONCURRENCY=2
MONITORING_DAILY_TIME=06:00
WEB_PUSH_SUBJECT=mailto:admin@example.com
WEB_PUSH_PRIVATE_KEY=

# Required server-side Vercel value for api/workspace.js proxy:
# BACKEND_URL=https://taghvim.onrender.com
#
# Production frontend value when not using same-origin Vercel rewrites:
# VITE_API_URL=https://taghvim.onrender.com

# In production, missing API configuration is treated as an integration error instead
# of silently using browser IndexedDB as the business-data source of truth.

# Browser auth bootstraps a fresh local Super Admin in IndexedDB when no Super Admin exists.
# Current bootstrap credentials are defined in frontend/src/services/auth-service.ts.

# Production builds must move authentication enforcement to Tauri/Rust commands
# and use OS/secure storage or server-side sessions.
ZAMBIL_SESSION_HOURS=12
ZAMBIL_MAX_FAILED_LOGINS=5
ZAMBIL_LOCK_MINUTES=15

# Backup and disaster recovery. Keep values server-side only.
BACKUP_ENVIRONMENT=development
BACKUP_DATABASE_URL=
BACKUP_STORAGE_DIR=
BACKUP_STORAGE_ENCRYPTED=true
BACKUP_TEMP_DIR=.tmp/backups
BACKUP_CATALOG_PATH=.backup-catalog/development.json
BACKUP_RETENTION_CLASS=daily
BACKUP_RETENTION_DRY_RUN=true
BACKUP_ALERT_WEBHOOK_URL=
BACKUP_RPO_HOURS=24
BACKUP_RESTORE_DRILL_DAYS=90
BACKUP_LAST_SUCCESS_AT=
BACKUP_LAST_RESTORE_TEST_AT=
RESTORE_TEST_DATABASE_URL=
DB_MIGRATION_VERSION=backend/database/postgres/002_backup_catalog.sql
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
PSQL_BIN=psql
