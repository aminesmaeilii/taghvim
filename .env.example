# Public Vite variables. Only variables prefixed with VITE_ are exposed to the browser bundle.
VITE_APP_NAME=Zambil Content Calendar

# No production backend is configured for the Vercel web build yet.
# The web build stores workspace/auth data locally in IndexedDB.

# Development bootstrap password for the first local Super Admin.
# Current browser/dev auth implementation uses "password" as the development fallback.
# Do not use this as a real production secret in a browser-only deployment.
ZAMBIL_BOOTSTRAP_ADMIN_PASSWORD=password

# Production builds must move authentication enforcement to Tauri/Rust commands
# and use OS/secure storage or server-side sessions.
ZAMBIL_SESSION_HOURS=12
ZAMBIL_MAX_FAILED_LOGINS=5
ZAMBIL_LOCK_MINUTES=15
