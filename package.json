{
  "name": "rooznegar-content-calendar",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "workspaces": ["frontend", "backend"],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build",
    "preview": "npm --workspace frontend run preview",
    "lint": "eslint .",
    "typecheck": "tsc -b && tsc -p backend/tsconfig.json",
    "test": "npm --workspace frontend run test",
    "test:run": "npm --workspace frontend run test:run",
    "test:watch": "npm --workspace frontend run test:watch",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "verify": "npm run typecheck && npm run lint && npm run test:run && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource/vazirmatn": "^5.1.1",
    "@hookform/resolvers": "^4.1.3",
    "@tanstack/react-query": "^5.66.8",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.2.1",
    "@upstash/redis": "^1.38.0",
    "jalaali-js": "^1.2.8",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jalaali-js": "^1.2.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}
