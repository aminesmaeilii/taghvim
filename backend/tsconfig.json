{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src", "../shared/**/*.ts"],
  "exclude": ["../shared/**/*.test.ts", "../shared/**/*.spec.ts"]
}
